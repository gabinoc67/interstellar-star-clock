<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Cash 5 MBI Matrix Engine</title>
<style>
:root{--bg:#fff;--p:#f7f9fc;--p2:#eef3f9;--t:#172033;--m:#5c6b82;--b:#cfd8e6;--a:#174ea6;--g:#0b6e4f;--r:#9b1c1c;--v:#403899;--sh:0 8px 22px rgba(20,40,80,.12)}
*{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--t);font-family:Arial,Helvetica,sans-serif;line-height:1.45}
header{padding:22px 18px;text-align:center;border-bottom:1px solid var(--b)}
h1{margin:0;font-size:clamp(22px,3vw,34px)}
header p{margin:8px auto 0;max-width:1050px;color:var(--m)}
main{max-width:1280px;margin:0 auto;padding:18px}
.card{background:#fff;border:1px solid var(--b);border-radius:14px;box-shadow:var(--sh);padding:16px;margin:0 0 16px}
textarea{width:100%;resize:vertical;border:1px solid var(--b);border-radius:12px;padding:12px;font-family:Consolas,monospace;font-size:14px}
#dataInput{min-height:260px}
#testInput{min-height:105px}
.button-row{display:flex;gap:12px;flex-wrap:wrap;margin-top:12px}
button{border:0;border-radius:12px;padding:13px 18px;font-weight:bold;cursor:pointer;color:#fff;background:var(--a)}
button:nth-child(2){background:var(--g)}
button:nth-child(3){background:var(--v)}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}
.stat{background:var(--p);border:1px solid var(--b);border-radius:12px;padding:12px}
.stat b{font-size:19px}
.small{font-size:13px;color:var(--m)}
table{width:100%;border-collapse:collapse;font-size:13px}
th,td{border:1px solid var(--b);padding:6px 7px;text-align:center}
th{background:var(--p2)}
.section-title{margin:0 0 10px;font-size:20px}
.ticket-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(215px,1fr));gap:10px}
.ticket{border:1px solid var(--b);border-radius:12px;background:var(--p);padding:10px}
.nums{font-size:20px;font-weight:bold;letter-spacing:1px}
.tag{display:inline-block;margin-top:5px;padding:3px 7px;border-radius:999px;background:#e7eefc;color:#174ea6;font-size:12px}
.warning{background:#fff8e6;border:1px solid #ecd28a;color:#5e4200}
.good{background:#eaf8f1;border:1px solid #b7e3cc;color:#0b6e4f}
.bad{background:#fff0f0;border:1px solid #efb6b6;color:#9b1c1c}
.matrix-scroll{overflow:auto;max-height:460px;border:1px solid var(--b);border-radius:12px}
#printArea{display:none}
@media print{
body *{visibility:hidden}
#printArea,#printArea *{visibility:visible}
#printArea{display:block;position:absolute;left:0;top:0;width:100%;padding:20px}
.no-print{display:none!important}
}
</style>
</head>
<body>
<header>
<h1>Cash 5 MBI Matrix Engine</h1>
<p>
Cash 5 numbers 1–35. Five drawn. Uses Position Matrix, Pair Matrix, Triple Memory,
Delay/Gap, Time Ratio, Transition Ratio, Entropy/Chaos, Machine Bias Index, and optional 3 test draws.
</p>
</header>

<main>
<section class="card no-print">
<h2 class="section-title">Paste Cash 5 Draw History</h2>
<p class="small">Paste historical drawings. One drawing per line. Dates are okay. The program extracts the last five valid numbers.</p>
<textarea id="dataInput" placeholder="09/20/2018, 3, 9, 18, 19, 35"></textarea>

<h2 class="section-title">Optional: Paste 3 Machine Test Draws</h2>
<p class="small">Paste the 3 pre-test draws here. If blank, the program uses the last 3 historical draws as a proxy.</p>
<textarea id="testInput" placeholder="Test 1: 2, 7, 14, 23, 30
Test 2: 1, 9, 18, 21, 35
Test 3: 4, 10, 19, 24, 34"></textarea>

<div class="button-row">
<button onclick="analyzeMatrix()">1. Analyze Matrix</button>
<button onclick="generateTickets()">2. Generate Next Possible 40 Tickets</button>
<button onclick="printTickets()">3. Print Generated Numbers</button>
</div>
</section>

<section id="messageBox" class="card warning no-print">Paste your history, then click <b>Analyze Matrix</b>.</section>
<section id="summaryBox" class="card no-print"></section>
<section id="matrixBox" class="card no-print"></section>
<section id="ticketBox" class="card no-print"></section>
<section id="printArea"></section>
</main>

<script>
const MIN=1,MAX=35,PICK=5,TICKET_COUNT=40;
const TOTAL_COMBINATIONS=combination(35,5);
let ENGINE={draws:[],tests:[],analysis:null,tickets:[]};

function factorial(n){let v=1;for(let i=2;i<=n;i++)v*=i;return v}
function combination(n,k){return factorial(n)/(factorial(k)*factorial(n-k))}
function avg(a){return a&&a.length?a.reduce((x,y)=>x+y,0)/a.length:0}
function variance(a){if(!a||a.length<2)return 0;let m=avg(a);return avg(a.map(x=>(x-m)*(x-m)))}
function clamp(x,a,b){return Math.max(a,Math.min(b,x))}
function norm(v,min,max){return max===min?0:clamp((v-min)/(max-min),0,1)}
function cap(v,max){return Math.min(v,max)}
function pairKey(a,b){return [a,b].sort((x,y)=>x-y).join("-")}
function triKey(a){return [...a].sort((x,y)=>x-y).join("-")}
function setMsg(t,type="warning"){let b=document.getElementById("messageBox");b.className="card no-print "+type;b.innerHTML=t}
function parseBox(id){
const raw=document.getElementById(id).value.trim();
if(!raw)return [];
const lines=raw.split(/\n+/).map(x=>x.trim()).filter(Boolean);
const draws=[];
for(const line of lines){
let nums=line.split(/[^0-9]+/).filter(Boolean).map(Number).filter(n=>n>=MIN&&n<=MAX);
if(nums.length>=5){
let d=[...new Set(nums.slice(-5))];
if(d.length===5)draws.push(d);
}
}
return draws;
}

function getPairs(arr){
const a=[...arr].sort((x,y)=>x-y),out=[];
for(let i=0;i<a.length;i++)for(let j=i+1;j<a.length;j++)out.push([a[i],a[j]]);
return out;
}

function getTriples(arr){
const a=[...arr].sort((x,y)=>x-y),out=[];
for(let i=0;i<a.length;i++)for(let j=i+1;j<a.length;j++)for(let k=j+1;k<a.length;k++)out.push([a[i],a[j],a[k]]);
return out;
}

function analyzeMatrix(){
const draws=parseBox("dataInput");
let tests=parseBox("testInput");
if(draws.length<20){setMsg("Need at least 20 valid Cash 5 drawings for matrix analysis.","bad");return}
if(tests.length===0)tests=draws.slice(-3);
tests=tests.slice(-3);

const total=draws.length,recentWindow=Math.min(60,total);
const posNames=["A","B","C","D","E"];
const pos={},freq={},recent={},lastSeen={},gaps={},pairMatrix={},pairCounts={},pairLast={},pairGaps={},tripleCounts={},transitionMatrix={};

for(let n=1;n<=35;n++){
pos[n]={A:0,B:0,C:0,D:0,E:0,total:0};
freq[n]=0;recent[n]=0;lastSeen[n]=-1;gaps[n]=[];
pairMatrix[n]={};transitionMatrix[n]={};
for(let m=1;m<=35;m++){pairMatrix[n][m]=0;transitionMatrix[n][m]=0}
}

for(let i=0;i<total;i++){
const draw=draws[i];

for(let p=0;p<5;p++){
const n=draw[p];
freq[n]++;
recent[n]+=i>=total-recentWindow?1:0;
pos[n][posNames[p]]++;
pos[n].total++;
if(lastSeen[n]>=0)gaps[n].push(i-lastSeen[n]);
lastSeen[n]=i;
}

for(const [a,b] of getPairs(draw)){
pairMatrix[a][b]++;pairMatrix[b][a]++;
const k=pairKey(a,b);
pairCounts[k]=(pairCounts[k]||0)+1;
if(pairLast[k]!==undefined){
if(!pairGaps[k])pairGaps[k]=[];
pairGaps[k].push(i-pairLast[k]);
}
pairLast[k]=i;
}

for(const tri of getTriples(draw)){
const k=triKey(tri);
tripleCounts[k]=(tripleCounts[k]||0)+1;
}

if(i>0){
const prev=draws[i-1];
for(const a of prev)for(const b of draw)transitionMatrix[a][b]++;
}
}

const testFreq={},testPair={},testTriple={};
for(let n=1;n<=35;n++)testFreq[n]=0;

for(const d of tests){
for(const n of d)testFreq[n]++;
for(const [a,b] of getPairs(d))testPair[pairKey(a,b)]=(testPair[pairKey(a,b)]||0)+1;
for(const tri of getTriples(d))testTriple[triKey(tri)]=(testTriple[triKey(tri)]||0)+1;
}

const avgFreq=(total*5)/35,lastDraw=draws[total-1],testFlat=tests.flat();
const rows=[];

for(let n=1;n<=35;n++){
const delay=lastSeen[n]===-1?total:total-1-lastSeen[n];
const averageGap=gaps[n].length?avg(gaps[n]):total;
const gapVar=variance(gaps[n]);
const gapStd=Math.sqrt(gapVar);
const entropy=calcEntropy(gaps[n],averageGap);
const chaosRatio=norm(gapStd/(averageGap+1),0,1.8);
const stabilityRatio=1-chaosRatio;
const chaosLabel=chaosRatio<.33?"Stable":chaosRatio<.66?"Mixed":"Chaotic";

const numberProb=freq[n]/(total*5);
const expectedProb=1/35;
const factorialWeight=numberProb/expectedProb;
const hotRatio=freq[n]/avgFreq;
const recentRatio=(recent[n]/recentWindow)/(5/35);
const timeRatio=(delay+1)/(averageGap+1);
const posMax=Math.max(pos[n].A,pos[n].B,pos[n].C,pos[n].D,pos[n].E);
const posRatio=pos[n].total?posMax/pos[n].total:0;

const pairStrength=cap(calcPairStrength(n,pairMatrix,total),0.75);
const tripleStrength=cap(calcTripleStrength(n,tripleCounts,total),0.55);
const transitionRatio=cap(calcTransitionRatio(n,lastDraw,transitionMatrix,total),0.45);
const testRatio=cap(testFreq[n]/3,1);

const randomBase=1;
const mbi=
(0.28*(hotRatio-randomBase))+
(0.18*(recentRatio-randomBase))+
(0.20*(timeRatio-randomBase))+
(0.12*(pairStrength-.18))+
(0.08*(tripleStrength-.10))+
(0.08*(transitionRatio-.05))+
(0.06*(testRatio-.14));

const mbiLabel=mbi>.16?"Positive MBI":mbi<-.10?"Negative MBI":"Near-Zero MBI";

const rawScore=
0.15*norm(hotRatio,0,2.2)+
0.10*norm(recentRatio,0,2.4)+
0.14*norm(timeRatio,0,3.5)+
0.10*norm(pairStrength,0,.75)+
0.06*norm(tripleStrength,0,.55)+
0.06*norm(transitionRatio,0,.45)+
0.07*norm(posRatio,.15,.45)+
0.06*norm(factorialWeight,0,2.2)+
0.08*stabilityRatio+
0.08*chaosRatio+
0.10*norm(testRatio,0,1);

rows.push({n,A:pos[n].A,B:pos[n].B,C:pos[n].C,D:pos[n].D,E:pos[n].E,total:freq[n],recent:recent[n],
delay,averageGap,gapVar,entropy,chaosRatio,stabilityRatio,chaosLabel,numberProb,factorialWeight,hotRatio,
recentRatio,timeRatio,posRatio,pairStrength,tripleStrength,transitionRatio,testRatio,mbi,mbiLabel,score:rawScore});
}

rows.sort((a,b)=>b.score-a.score);
const sum=rows.reduce((s,r)=>s+r.score,0);
rows.forEach((r,i)=>{r.rank=i+1;r.finalProb=sum?r.score/sum:0});

const positive=rows.filter(x=>x.mbiLabel==="Positive MBI");
const zero=rows.filter(x=>x.mbiLabel==="Near-Zero MBI");
const negative=rows.filter(x=>x.mbiLabel==="Negative MBI");
const hot=rows.slice(0,15),hotTop=hot.slice(0,8),hotBottom=hot.slice(8,15),warm=rows.slice(15,27),cold=rows.slice(27);
const recovery=[...rows].sort((a,b)=>b.timeRatio-a.timeRatio).slice(0,12);
const stable=rows.filter(x=>x.chaosLabel==="Stable"),chaotic=rows.filter(x=>x.chaosLabel==="Chaotic");

const topPairs=Object.entries(pairCounts).map(([key,count])=>{
const [a,b]=key.split("-").map(Number);
const delay=pairLast[key]===undefined?total:total-1-pairLast[key];
const ag=pairGaps[key]&&pairGaps[key].length?avg(pairGaps[key]):total;
const testBoost=testPair[key]?0.12:0;
const score=cap((count/total)*0.65+norm((delay+1)/(ag+1),0,3)*0.23+testBoost,0.75);
return{key,a,b,count,delay,avgGap:ag,score};
}).sort((a,b)=>b.score-a.score).slice(0,50);

const topTriples=Object.entries(tripleCounts).map(([key,count])=>{
const nums=key.split("-").map(Number);
const testBoost=testTriple[key]?0.10:0;
return{key,nums,count,score:cap(count/total+testBoost,0.55)};
}).sort((a,b)=>b.score-a.score).slice(0,40);

ENGINE.draws=draws;ENGINE.tests=tests;
ENGINE.analysis={total,tests,rows,positive,zero,negative,hot,hotTop,hotBottom,warm,cold,recovery,stable,chaotic,topPairs,topTriples,pairCounts,tripleCounts,lastDraw};
renderAnalysis();
setMsg("Matrix complete. Added 3-test-draw influence and Machine Bias Index mixing: Positive MBI, Near-Zero MBI, and Negative MBI.","good");
}
function calcEntropy(gaps,averageGap){
if(!gaps||gaps.length<2)return 0;
const bins={short:0,normal:0,long:0};
for(const g of gaps){
if(g<averageGap*.70)bins.short++;
else if(g>averageGap*1.30)bins.long++;
else bins.normal++;
}
const total=gaps.length;let e=0;
for(const k in bins){const p=bins[k]/total;if(p>0)e-=p*Math.log2(p)}
return e/Math.log2(3);
}

function calcPairStrength(n,matrix,total){
let s=0,c=0;
for(let m=1;m<=35;m++){if(m!==n&&matrix[n][m]>0){s+=matrix[n][m]/total;c++}}
return c?(s/c)*10:0;
}
function calcTripleStrength(n,triples,total){
let s=0,c=0;
for(const [key,v] of Object.entries(triples)){
if(key.split("-").map(Number).includes(n)){s+=v/total;c++}
}
return c?(s/c)*30:0;
}
function calcTransitionRatio(n,lastDraw,tm,total){
let s=0;for(const p of lastDraw)s+=tm[p][n]||0;
return s/(total*5);
}

function renderAnalysis(){
const a=ENGINE.analysis;
document.getElementById("summaryBox").innerHTML=`
<h2 class="section-title">Automatic Matrix Summary</h2>
<div class="grid">
<div class="stat"><b>${a.total}</b><br><span class="small">Historical drawings</span></div>
<div class="stat"><b>${TOTAL_COMBINATIONS.toLocaleString()}</b><br><span class="small">N! combinations: 35! / 5!30!</span></div>
<div class="stat"><b>${a.tests.map(x=>x.join("-")).join(" | ")}</b><br><span class="small">3 machine test draws used</span></div>
<div class="stat"><b>${a.positive.map(x=>x.n).join(", ")||"none"}</b><br><span class="small">Positive MBI</span></div>
<div class="stat"><b>${a.zero.map(x=>x.n).join(", ")||"none"}</b><br><span class="small">Near-Zero MBI</span></div>
<div class="stat"><b>${a.negative.map(x=>x.n).join(", ")||"none"}</b><br><span class="small">Negative MBI</span></div>
</div>
<p class="small"><b>Important:</b> This is a machine-behavior analyzer, not a guarantee. Lottery drawings are random; past output and test draws do not prove future results.</p>
`;

document.getElementById("matrixBox").innerHTML=`
<h2 class="section-title">Matrix Table with MBI</h2>
<div class="matrix-scroll">
<table>
<thead><tr>
<th>Rank</th><th>#</th><th>A</th><th>B</th><th>C</th><th>D</th><th>E</th><th>Total</th><th>Recent</th>
<th>Delay</th><th>Avg Gap</th><th>Entropy</th><th>Chaos</th><th>Time</th><th>Pair</th><th>Triple</th><th>Trans</th><th>Test</th><th>MBI</th><th>MBI Type</th><th>Final %</th>
</tr></thead>
<tbody>
${a.rows.map(r=>`
<tr>
<td>${r.rank}</td><td><b>${r.n}</b></td>
<td>${r.A}</td><td>${r.B}</td><td>${r.C}</td><td>${r.D}</td><td>${r.E}</td>
<td>${r.total}</td><td>${r.recent}</td><td>${r.delay}</td><td>${r.averageGap.toFixed(1)}</td>
<td>${r.entropy.toFixed(2)}</td><td>${r.chaosLabel}</td><td>${r.timeRatio.toFixed(2)}</td>
<td>${r.pairStrength.toFixed(3)}</td><td>${r.tripleStrength.toFixed(3)}</td><td>${r.transitionRatio.toFixed(3)}</td>
<td>${r.testRatio.toFixed(2)}</td><td>${r.mbi.toFixed(3)}</td><td>${r.mbiLabel}</td><td>${(r.finalProb*100).toFixed(2)}%</td>
</tr>`).join("")}
</tbody>
</table>
</div>
<h3>Strong Pair Matrix</h3>
<p>${a.topPairs.slice(0,20).map(p=>p.key+"("+p.count+")").join(", ")}</p>
<h3>Strong Triple Memory</h3>
<p>${a.topTriples.slice(0,15).map(t=>t.key+"("+t.count+")").join(", ")}</p>
`;
}

function generateTickets(){
if(!ENGINE.analysis){setMsg("Click Analyze Matrix first.","bad");return}
const a=ENGINE.analysis,tickets=[],used=new Set(),usage={};
for(let n=1;n<=35;n++)usage[n]=0;

const patterns=[
{name:"MBI Balanced",groups:[["positive",2],["zero",2],["negative",1]],pair:0,triple:0},
{name:"Positive MBI Pair",groups:[["positive",1],["zero",1],["warm",1]],pair:1,triple:0},
{name:"Near-Zero Control",groups:[["zero",3],["positive",1],["negative",1]],pair:0,triple:0},
{name:"Negative Recovery",groups:[["negative",2],["recovery",1],["positive",1],["zero",1]],pair:0,triple:0},
{name:"Test Draw Echo",groups:[["hotBottom",1],["zero",2],["recovery",2]],pair:0,triple:0},
{name:"Triple Network",groups:[["positive",1],["negative",1]],pair:0,triple:1},
{name:"Stable Chaotic Mix",groups:[["stable",2],["chaotic",2],["zero",1]],pair:0,triple:0},
{name:"Top Bottom Mix",groups:[["hotTop",2],["hotBottom",2],["negative",1]],pair:0,triple:0}
];

let guard=0;
while(tickets.length<TICKET_COUNT&&guard<6000){
guard++;
const pat=patterns[tickets.length%patterns.length];
let ticket=[];

if(pat.pair){const p=pickPair(a.topPairs,usage);if(p)ticket.push(p.a,p.b)}
if(pat.triple){const t=pickTriple(a.topTriples,usage);if(t)ticket.push(...t.nums)}

for(const [name,count] of pat.groups)addGroup(ticket,a[name],count,usage);

while(ticket.length<5){
const pool=[...a.positive,...a.zero,...a.negative,...a.warm,...a.recovery];
const x=pickNumber(pool,usage);
if(x&&!ticket.includes(x.n))ticket.push(x.n);else break;
}

ticket=[...new Set(ticket)].filter(n=>n>=1&&n<=35).sort((x,y)=>x-y);
if(ticket.length!==5)continue;
if(!passesBalance(ticket))continue;
const key=ticket.join("-");
if(used.has(key))continue;

used.add(key);ticket.forEach(n=>usage[n]++);
tickets.push({nums:ticket,type:pat.name,score:scoreTicket(ticket,a),profile:ticketProfile(ticket,a)});
}

tickets.sort((x,y)=>y.score-x.score);
ENGINE.tickets=tickets.slice(0,TICKET_COUNT);
renderTickets();
setMsg("Generated "+ENGINE.tickets.length+" tickets mixed by Positive MBI, Near-Zero MBI, Negative MBI, test draws, pairs, triples, time ratio, and entropy.","good");
}

function addGroup(ticket,group,count,usage){
for(let i=0;i<count;i++){const x=pickNumber(group,usage);if(x&&!ticket.includes(x.n))ticket.push(x.n)}
}

function pickNumber(group,usage){
if(!group||!group.length)return null;
let pool=group.filter(x=>usage[x.n]<8);
if(!pool.length)pool=group;
let total=0;
const weights=pool.map((x,idx)=>{
const usePenalty=1/(1+usage[x.n]);
const rankMix=.65+((pool.length-idx)/pool.length)*.35;
const mbiMix=x.mbiLabel==="Near-Zero MBI"?1.08:1;
const w=Math.max(.0001,(x.score+.04)*usePenalty*rankMix*mbiMix);
total+=w;return w;
});
let r=Math.random()*total;
for(let i=0;i<pool.length;i++){r-=weights[i];if(r<=0)return pool[i]}
return pool[pool.length-1];
}

function pickPair(pairs,usage){
let pool=pairs.filter(p=>usage[p.a]<8&&usage[p.b]<8);
if(!pool.length)pool=pairs;
return pool[Math.floor(Math.random()*Math.min(pool.length,20))];
}

function pickTriple(triples,usage){
let pool=triples.filter(t=>t.nums.every(n=>usage[n]<8));
if(!pool.length)pool=triples;
return pool[Math.floor(Math.random()*Math.min(pool.length,15))];
}

function passesBalance(t){
const sum=t.reduce((a,b)=>a+b,0);
const low=t.filter(n=>n<=17).length,high=5-low;
const odd=t.filter(n=>n%2).length,even=5-odd;
return !(sum<45||sum>135||low===0||high===0||odd===0||even===0);
}

function scoreTicket(t,a){
let s=0;
for(const n of t){const r=a.rows.find(x=>x.n===n);if(r)s+=r.finalProb}
for(const [x,y] of getPairs(t)){const k=pairKey(x,y);if(a.pairCounts[k])s+=Math.min((a.pairCounts[k]/a.total)*.25,.05)}
for(const tri of getTriples(t)){const k=triKey(tri);if(a.tripleCounts[k])s+=Math.min((a.tripleCounts[k]/a.total)*.35,.04)}
return s;
}

function ticketProfile(t,a){
let pos=0,zero=0,neg=0;
for(const n of t){
const r=a.rows.find(x=>x.n===n);
if(!r)continue;
if(r.mbiLabel==="Positive MBI")pos++;
else if(r.mbiLabel==="Negative MBI")neg++;
else zero++;
}
return `Positive ${pos}, Near-Zero ${zero}, Negative ${neg}`;
}

function renderTickets(){
const tickets=ENGINE.tickets;
document.getElementById("ticketBox").innerHTML=`
<h2 class="section-title">Next Possible 40 Machine-Behavior Tickets</h2>
<p class="small">These tickets mix Positive MBI, Near-Zero MBI, Negative MBI, test-draw echo, pair memory, triple memory, time ratio, transition ratio, and entropy.</p>
<div class="ticket-grid">
${tickets.map((t,i)=>`
<div class="ticket">
<strong>Ticket ${i+1}</strong>
<div class="nums">${t.nums.map(n=>String(n).padStart(2,"0")).join(" - ")}</div>
